[Unit]
Description=Clipsy replay buffer and recording daemon
After=graphical-session.target

[Service]
Type=simple
WorkingDirectory=%h/clipping
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/python -m clipsy daemon
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
